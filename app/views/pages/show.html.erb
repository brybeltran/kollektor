<%= link_to "← Back", pages_path, class: "text-blue-700 underline" %>

<h1 class="text-2xl font-bold mt-4 mb-2"><%= @page.title || @page.url %></h1>

<% if @links.any? %>
  <table class="table-auto mt-6 w-full text-left">
    <thead>
      <tr class="border-b">
        <th class="py-2 px-4">Label</th>
        <th class="py-2 px-4">Href</th>
      </tr>
    </thead>
    <tbody>
      <% @links.each do |link| %>
        <tr class="border-b">
          <td class="py-2 "><%= raw link.label %></td>
          <td class="py-2"><%= link_to link.href, link.href,
                                      target: "_blank",
                                      rel: "noopener" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="flex justify-center mt-4">
    <%== pagy_nav(@pagy) %>
  </div>
<% else %>
  <p class="mt-8 text-center text-gray-500">
    No links were found on this page.
  </p>
<% end %>

<div class="mt-4">
  <%= button_to "Delete this page", page_path(@page),
              data: { confirm: "Are you sure?" },
              method: :delete,
              class: "bg-red-600 text-white px-4 py-2 rounded" %>
</div>
